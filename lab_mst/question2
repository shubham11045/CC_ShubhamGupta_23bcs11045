public class onlyone {
   public static int one_appear(int nums[]){
    int ones =0;
    int twos =0;
    for(int num:nums){
        ones=(ones^num)& ~twos;
        twos =(twos^num)& ~ones;
    }
    return ones;

   } 
   public static void main(String[] args) {
    //int nums[]={1,2,2,2};
   int nums[]={1,2,3,3,3,2,2};
    System.out.println(one_appear(nums));
    
   }
}
